{
  "include": ["src", "background.ts", "vite-env.d.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    /* 타입 */
    "types": ["chrome", "vite/client"],

    /* 번들러 */
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,

    /* 안정성 */
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    /* 경로 */
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
